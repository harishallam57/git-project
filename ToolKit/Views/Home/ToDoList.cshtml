@{
    ViewData["Title"] = "Priority To-Do List";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 fade-in-up">
            <div class="glass-card p-5">
                <div class="text-center mb-5">
                    <span class="tool-icon">📋</span>
                    <h2 class="display-5 fw-bold gradient-text">Priority Tasks</h2>
                    <p class="text-muted">Stay organized with a beautiful and simple task manager.</p>
                </div>

                <div class="input-group mb-5 input-group-lg">
                    <input type="text" id="taskInput" class="form-control bg-dark border-secondary text-white p-3 px-4 rounded-start-pill" placeholder="What needs to be done?">
                    <button class="btn btn-premium px-5 rounded-end-pill" onclick="addTask()">Add Task</button>
                </div>

                <div class="task-container">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="text-light-50 fw-600 mb-0">Active Tasks</h5>
                        <span id="taskCount" class="badge rounded-pill bg-secondary px-3">0</span>
                    </div>
                    <ul id="taskList" class="list-group list-group-flush border-0">
                        <!-- Tasks will appear here -->
                    </ul>
                    <div id="noTasks" class="text-center py-5">
                        <p class="text-muted opacity-50 italic">Your list is currently empty. Start by adding a task above!</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    #taskList .list-group-item {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        margin-bottom: 12px;
        transition: 0.3s;
        color: white;
        padding: 1.25rem 1.5rem;
    }
    #taskList .list-group-item:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(99, 102, 241, 0.3);
        transform: translateX(5px);
    }
    .task-text { flex-grow: 1; }
    .btn-delete {
        color: #ef4444;
        background: none;
        border: none;
        opacity: 0.5;
        transition: 0.3s;
    }
    .btn-delete:hover {
        opacity: 1;
        transform: scale(1.1);
    }
</style>

@section Scripts {
    <script>
        let count = 0;

        function updateUI() {
            const noTasks = document.getElementById("noTasks");
            const countBadge = document.getElementById("taskCount");
            noTasks.style.display = count === 0 ? "block" : "none";
            countBadge.innerText = count;
        }

        function addTask() {
            const input = document.getElementById("taskInput");
            const task = input.value.trim();
            if (task === "") {
                alert("Task cannot be empty");
                return;
            }

            const li = document.createElement("li");
            li.className = "list-group-item d-flex justify-content-between align-items-center fade-in-up";
            li.innerHTML = `
                <span class="task-text">${task}</span>
                <button class="btn-delete" onclick="deleteTask(this)">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </button>
            `;

            document.getElementById("taskList").appendChild(li);
            input.value = "";
            count++;
            updateUI();
        }

        function deleteTask(btn) {
            btn.closest("li").style.opacity = "0";
            setTimeout(() => {
                btn.closest("li").remove();
                count--;
                updateUI();
            }, 300);
        }

        document.getElementById("taskInput").addEventListener("keypress", (e) => {
            if (e.key === "Enter") addTask();
        });
    </script>
}